{
  "name": "@y2k-network/passkit",
  "version": "0.1.0",
  "description": "Effect-native library for Apple Wallet + Google Wallet passes — one pass, two wallets",
  "module": "index.ts",
  "type": "module",
  "license": "MIT",
  "author": "Austin Buckler",
  "keywords": [
    "effect",
    "apple-wallet",
    "passkit",
    "google-wallet",
    "pkpass",
    "wallet-objects",
    "passes",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/y2k-network/passkit.git"
  },
  "homepage": "https://github.com/y2k-network/passkit#readme",
  "bugs": {
    "url": "https://github.com/y2k-network/passkit/issues"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "DESIGN.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "check": "tsc --noEmit",
    "prepublishOnly": "bun run check && bun test && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-forge": "^1.3.14",
    "effect": "^4.0.0-beta.97"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.97",
    "typescript": "^5"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "node-forge": "^1.4.0"
  }
}
